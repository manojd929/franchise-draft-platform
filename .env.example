# Supabase Dashboard → Connect → ORM (two URLs). Username is postgres.<project-ref> — copy exactly.
# Runtime (Prisma adapter / pg): transaction pooler
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-[n]-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI (migrate, db seed): session-style pooler on 5432 — required for migrate deploy over IPv4.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-[n]-[region].pooler.supabase.com:5432/postgres"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Required for “Create franchise owner login” on Franchises page (server-only; never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Vercel Blob — enables franchise logo & athlete photo uploads from the app (Hobby includes free quota; see Vercel docs).
BLOB_READ_WRITE_TOKEN=""

# Optional — canonical browser origin for links printed by `npm run seed:demo-tournament` (set to your Vercel URL in Production).
NEXT_PUBLIC_APP_ORIGIN="https://your-deployment.vercel.app"

# Demo tournament seed (`npm run seed:demo-tournament`) — optional overrides / stdout safety (run locally, never on Vercel):
# DEMO_SEED_COMMISSIONER_EMAIL=
# DEMO_SEED_COMMISSIONER_PASSWORD=
# DEMO_SEED_OWNER_1_EMAIL=
# DEMO_SEED_OWNER_1_PASSWORD=
# DEMO_SEED_OWNER_2_EMAIL=
# DEMO_SEED_OWNER_2_PASSWORD=
# DEMO_SEED_TOURNAMENT_NAME=
# DEMO_SEED_PRINT_CREDENTIALS=0
